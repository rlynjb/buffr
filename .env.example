# Copy to .env and fill in. .env is gitignored — never commit real creds.

# reindb connection (Supabase Postgres). The laptop runtime + integration tests
# read this; integration tests SKIP when it is unset.
# Format: postgres://USER:PASSWORD@HOST:PORT/reindb
DATABASE_URL=

# Which app the laptop runtime writes as (app_id in the shared agents schema).
AGENT_APP_ID=laptop

# Schema holding the agent layer.
AGENT_DB_SCHEMA=agents

# Local Ollama (Gemma + nomic embeddings).
OLLAMA_HOST=http://localhost:11434
