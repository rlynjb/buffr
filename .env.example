# ===========================================
# buffr — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# At minimum, configure one LLM provider.

# -------------------------------------------
# LLM Providers (configure one or more)
# Only providers with keys set will appear in the UI.
# -------------------------------------------

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (GPT)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google (Gemini)
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-1.5-pro

# Ollama (Local models)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Default provider on app load (one of: anthropic, openai, google, ollama)
# DEFAULT_LLM_PROVIDER=anthropic

# -------------------------------------------
# GitHub
# -------------------------------------------
# Personal Access Token with repo scope
# GITHUB_TOKEN=ghp_...

# -------------------------------------------
# Notion (optional)
# -------------------------------------------
# Integration token from https://www.notion.so/my-integrations
# NOTION_TOKEN=ntn_...
# Database ID for task tracking
# NOTION_DATABASE_ID=...

# -------------------------------------------
# Authentication
# -------------------------------------------
# Single-user login credentials
# AUTH_USERNAME=rein
# AUTH_PASSWORD=buffr2026
# Secret key for signing JWT tokens (use a long random string)
# AUTH_SECRET=change-me-to-a-random-secret

# -------------------------------------------
# Netlify
# -------------------------------------------
# Personal Access Token
# NETLIFY_TOKEN=...
